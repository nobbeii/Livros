import requests

def buscar_livro_real(titulo):
    # API da Open Library - Gratuita e Sem Chave
    url = f"https://openlibrary.org/search.json?q={titulo.replace(' ', '+')}"
    
    print(f"Buscando por: {titulo}...")
    response = requests.get(url)
    
    if response.status_code == 200:
        dados = response.json()
        if dados['docs']:
            livro = dados['docs'][0]
            print(f"\n✅ Encontrado!")
            print(f"Título: {livro.get('title')}")
            print(f"Autor: {', '.join(livro.get('author_name', ['Desconhecido']))}")
            print(f"Ano: {livro.get('first_publish_year')}")
            print(f"Link: https://openlibrary.org{livro.get('key')}")
        else:
            print("Nada encontrado.")
    else:
        print("Erro na conexão.")

# Exemplo de uso com um tema "poderoso"
buscar_livro_real("The Diary of Anne Frank")
